{
  "name": "arduino-leonardo",
  "version": "0.1.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/arduinoLeonardo.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "Arduino Leonardo",
    "deviceId": "arduinoLeonardo",
    "arch": [
      "arduino-avr-usb"
    ],
    "manufactor": "arduino.cc",
    "learnMore": "https://docs.arduino.cc/hardware/leonardo",
    "type": "arduino",
    "iconURL": "./assets/arduinoLeonardo.png",
    "description": {
      "formatMessage": {
        "id": "arduinoLeonardo.description",
        "default": "The classic Arduino board that can act as a mouse or keyboard."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "57600",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/arduinoLeonardo-illustration.svg",
    "connectionSmallIconURL": "./assets/arduinoLeonardo-small.svg",
    "main": "./src/arduinoLeonardo.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "toolchains": "arduino-arduino-avr",
    "programMode": [
      "upload"
    ],
    "tags": [
      "arduino"
    ],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/arduino-leonardo",
    "libraries": "./libraries",
    "examples": [
      {
        "id": "blink",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.blink.name",
            "default": "Blink"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.blink.description",
            "default": "Make the on-board LED blink."
          }
        },
        "file": "./examples/blink.ob"
      },
      {
        "id": "button",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.button.name",
            "default": "Button"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.button.description",
            "default": "Light up the LED while a push button is pressed."
          }
        },
        "file": "./examples/button.ob"
      },
      {
        "id": "fade",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.fade.name",
            "default": "Fade"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.fade.description",
            "default": "Smoothly fade an LED in and out using PWM."
          }
        },
        "file": "./examples/fade.ob"
      },
      {
        "id": "knob",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.knob.name",
            "default": "Knob"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.knob.description",
            "default": "Control LED brightness with a potentiometer."
          }
        },
        "file": "./examples/knob.ob"
      },
      {
        "id": "servoSweep",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.servoSweep.name",
            "default": "Servo Sweep"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.servoSweep.description",
            "default": "Sweep a servo back and forth between 0 and 180 degrees."
          }
        },
        "file": "./examples/servoSweep.ob"
      },
      {
        "id": "serialMonitor",
        "name": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.serialMonitor.name",
            "default": "Serial Monitor"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoLeonardo.examples.serialMonitor.description",
            "default": "Print analog readings to the Serial Monitor every half second."
          }
        },
        "file": "./examples/serialMonitor.ob"
      }
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
